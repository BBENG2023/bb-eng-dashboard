{
  "README": [
    null,
    {
      "A": "BB-ENG Dashboard — Data Master"
    },
    {
      "A": "Engineering overlay. Joined with Preconstruction Tracker + Timesheets by Power Automate to feed the dashboard."
    },
    {},
    {
      "A": "Architecture"
    },
    {
      "A": "Preconstruction Tracker",
      "B": "Authoritative commercial record (maintained by the business, weekly). Source for: contract value, customer, pipeline status, open/closed, conversion date."
    },
    {
      "A": "BB-ENG Master (this file)",
      "B": "Engineering overlay. Source for: BB-ENG Slice (£), PM % complete, RAG override, lead engineer, sector, notes, planned spend curves."
    },
    {
      "A": "Timesheets export",
      "B": "Actual hours booked per project, refreshed weekly. Source for: cumulative spend (× team rates), hours burned this week."
    },
    {
      "A": "Team Rates",
      "B": "Charge-out rates per person. Updated annually-ish."
    },
    {
      "A": "Power Automate flow",
      "B": "Joins all of the above into a single JSON the dashboard reads, hourly during work hours."
    },
    {},
    {
      "A": "How the join works"
    },
    {
      "A": "Lookup key",
      "B": "Project Code in this file matches Project Ref in the Preconstruction Tracker."
    },
    {
      "A": "Per scheme on the dashboard",
      "B": "Pull Customer, Pipeline Status, Open/Closed from Tracker. Pull % complete, RAG, lead, notes, BB-ENG Slice (£) from this file. Pull spend-to-date from Timesheets × Team Rates."
    },
    {
      "A": "Pipeline (£) headline",
      "B": "Sum of Tracker.Value where Open/Closed = Open AND Pipeline Status ≠ Secured."
    },
    {
      "A": "Live Backlog (£) headline",
      "B": "Sum of Master.BB-ENG Slice (£) where Master.Status = Live."
    },
    {
      "A": "Archive count",
      "B": "Count of Master.Status = Archived (or Tracker rows where Open/Closed = Closed)."
    },
    {},
    {
      "A": "Sheets in this workbook"
    },
    {
      "A": "1. Project Master",
      "B": "One row per BB-ENG scheme (Live, Pipeline, Archived). The engineering overlay."
    },
    {
      "A": "2. Planned Spend",
      "B": "Monthly cumulative planned spend per Live scheme. Drives the planned S-curve on Chart 1."
    },
    {
      "A": "3. Team Rates",
      "B": "Charge-out rates per team member. Converts booked hours to £ spent."
    },
    {
      "A": "4. Pipeline",
      "B": "Opportunities not yet secured. Feeds the pipeline tile and pipeline panel."
    },
    {
      "A": "5. Settings",
      "B": "RAG thresholds, dashboard cycle timing, refresh cadence, brand tokens, file paths."
    },
    {},
    {
      "A": "Cell colour conventions"
    },
    {
      "A": "Blue text (input)",
      "B": "Values you fill in manually. Overtype freely."
    },
    {
      "A": "Black text (formula)",
      "B": "Calculated — don&apos;t overwrite."
    },
    {
      "A": "RAG fills",
      "B": "Green/Amber/Red conditional formatting on RAG column. Set RAG Override to Auto, G, A or R."
    },
    {},
    {
      "A": "BB-ENG Slice (£) — the key engineering field"
    },
    {
      "A": "What it is",
      "B": "The £ value of BB-ENG&apos;s deliverable on the scheme. Set at project award, doesn&apos;t change unless scope changes."
    },
    {
      "A": "Examples",
      "B": "Pure design / inspection / options contract = full fee value. TWD-only on a construction contract = £15–40k typical. Full design+build where BB-ENG owns design = a defined £ slice of the total contract."
    },
    {
      "A": "If blank",
      "B": "Scheme excluded from Live Backlog; flagged on dashboard for attention."
    },
    {},
    {
      "A": "To populate / maintain"
    },
    {
      "A": "Step 1",
      "B": "Project Master pre-seeded with 20 schemes. Confirm Project Codes match the Tracker."
    },
    {
      "A": "Step 2",
      "B": "Overtype BB-ENG Slice (£), Start, Planned End and Forecast End with accurate values per scheme."
    },
    {
      "A": "Step 3",
      "B": "Planned Spend curves are seeded as straight-line ramps to BB-ENG Slice. Replace with your own S-curve if you have one (typical front-loaded design profile: 20% in M1, 50% by M3, 85% by M6, 100% by M-end)."
    },
    {
      "A": "Step 4",
      "B": "RAG Override = Auto means dashboard calculates RAG. Set G/A/R to override (e.g. amber a scheme manually if you have soft intel)."
    },
    {
      "A": "Step 5",
      "B": "Save back to SharePoint with the same filename. Power Automate flow re-reads on the next cycle."
    }
  ],
